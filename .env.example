# --- Quadra data layer configuration ---

# Sui private key (bech32 "suiprivkey1...") for the data-layer writer.
# Funded with SUI (gas) and WAL (Walrus storage) on the chosen network.
DATA_SECRET_KEY=

# Network: "testnet" (default) or "mainnet".
DATA_NETWORK=testnet

# Optional Sui full node URL override (defaults to the public node for the network).
# DATA_BASE_URL=

# Walrus storage epochs per blob write.
DATA_EPOCHS=5

# Published `walrus_json` Move package id (the pointer package).
WALRUS_JSON_PACKAGE_ID=

# Published `quadra` Move package id (Seal namespace + seal_approve / job_access).
QUADRA_PACKAGE_ID=

# Shared `quadra::job_access::JobAccessRegistry` object id (printed at publish).
JOB_ACCESS_REGISTRY_ID=

# Shared `quadra::agent::AgentRegistry` object id (agents are read on-chain).
AGENT_REGISTRY_ID=

# Seal key server object ids (comma-separated) + decryption threshold. Required.
# `npm run setup` fills these with Mysten's allowlisted testnet servers.
SEAL_KEY_SERVER_IDS=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75,0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8
SEAL_THRESHOLD=1

# Watch: the watch service (npm run watch) subscribes to the Sui gRPC checkpoint
# stream. Optional gRPC(-web) endpoint override (default: fullnode for
# DATA_NETWORK) and reconnect backoff in ms.
# DATA_GRPC_URL=https://fullnode.testnet.sui.io:443
WATCH_RECONNECT_MS=2000

# Ports: REST writer service (PORT) and the separate watch/SSE service (WATCH_PORT).
PORT=8787
WATCH_PORT=8788

# --- Gateway write-authorization (RBAC) ---
# Per-engine role tokens sent as `x-quadra-role`. Each engine gets the matching
# token; the gateway enforces which role writes which database. Admin is a
# superuser. Generate strong random secrets.
ROLE_TOKEN_INTAKE=
ROLE_TOKEN_SCHEDULER=
ROLE_TOKEN_ADMIN=
# Allowed clock skew (ms) on agent-signed writes (register, store result).
AGENT_AUTH_WINDOW_MS=60000

# Engines write through the gateway at this URL (they read via the library).
DATA_GATEWAY_URL=http://localhost:8787

# Engines (intake, scheduler) read with an ephemeral key and write via the
# gateway, so they DO NOT need DATA_SECRET_KEY. For full isolation, run each
# engine with an env that omits DATA_SECRET_KEY and includes only its role token.

# --- Scheduler: evaluation engines (Nautilus) ---
# Maps each template's evaluator_id to its enclave (one enclave per evaluator).
# enclave_id is the on-chain enclave::Enclave object id (used to verify the signed
# score); omit it for local dev to skip verification. ROLE_TOKEN_SCHEDULER is
# required (scheduler writes). The finance evaluators:
# EVAL_ENGINES={"price-range-guess":{"url":"http://localhost:3001"},"up-down-guess":{"url":"http://localhost:3002"},"movement-percentage-guess":{"url":"http://localhost:3003"}}

# --- Engine ↔ engine wiring (intake + scheduler/validator) ---
# Shared secret for the validator's `POST /validate` (intake presents it; keep
# the route on a private network). Generate a strong random secret.
INTAKE_INTERNAL_TOKEN=
# Dedicated Seal-reader key for the scheduler/validator. Its address must be
# registered on-chain via `job_access::set_scheduler`. NOT the data master key.
SCHEDULER_SECRET_KEY=
# Where intake reaches the validator (the scheduler's server).
INTAKE_VALIDATOR_URL=http://localhost:4000

# --- Intake: on-chain payment objects ---
# Wallet that owns the IntakeCap (signs release_payment / refund_not_delivered),
# plus the IntakeCap and shared IntakeConfig object ids from the publish.
INTAKE_SECRET_KEY=
INTAKE_CAP_ID=
INTAKE_CONFIG_ID=

# --- Pointer object ids (fill in from `npm run bootstrap`) ---
POINTER_AGENT_SCORES=
POINTER_DELAYED_FAILED=
POINTER_JOB_TEMPLATES=
POINTER_JOB_SCHEDULER=
POINTER_JOB_RESULTS_INDEX=
