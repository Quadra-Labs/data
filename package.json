{
    "name": "quadra-data",
    "version": "0.1.0",
    "description": "Quadra Data Layer: read/write/watch the Quadra databases over Walrus, Seal, and Walrus Memory (MemWal).",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "setup": "tsx sandbox/setup-env.ts",
        "bootstrap": "tsx src/bootstrap.ts",
        "serve": "tsx src/server.ts",
        "watch": "tsx src/watch-server.ts",
        "sandbox": "tsx sandbox/integration.ts",
        "test:gateway": "tsx test/gateway-auth.ts"
    },
    "keywords": [
        "quadra",
        "walrus",
        "seal",
        "sui",
        "data-layer"
    ],
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@mysten/seal": "^1.1.3",
        "@mysten/sui": "^2.17.0",
        "@mysten/walrus": "^1.1.7",
        "fastify": "^5.8.5",
        "undici": "^7.0.0",
        "walrus-json": "file:../walrus-json"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "prettier": "^3.4.0",
        "tsup": "^8.5.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
